---
import MainLayout from '@/layouts/MainLayout.astro';

interface Props {
  lang?: string;
  title: string;
  description: string;
  target: string;
  linkLabel: string;
}

const { lang = 'en', title, description, target, linkLabel } = Astro.props;
---

<MainLayout
  lang={lang}
  title={title}
  customDescription={description}
  customOgTitle={title}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: title,
    description,
    url: `https://hawthornscapes.com${target}`,
    inLanguage: lang === 'fr' ? 'fr' : 'en-US',
  }}
>
  <section class="mx-auto max-w-3xl px-4 py-24 text-center sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold text-neutral-900 dark:text-neutral-100">
      {lang === 'fr' ? 'Page déplacée' : 'Page moved'}
    </h1>
    <p class="mt-4 text-base text-neutral-600 dark:text-neutral-400">
      {description}
    </p>
    <p class="mt-8">
      <a
        href={target}
        class="inline-flex items-center justify-center rounded-lg bg-brand-700 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-800"
      >
        {linkLabel}
      </a>
    </p>
  </section>
  <script
    is:inline
    set:html={`window.location.replace(${JSON.stringify(target)});`}
  />
</MainLayout>
