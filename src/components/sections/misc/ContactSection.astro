---
// Import the necessary dependencies.
import ContactIconBlock from '@components/ui/blocks/ContactIconBlock.astro';
import TextInput from '@components/ui/forms/input/TextInput.astro';
import EmailContactInput from '@components/ui/forms/input/EmailContactInput.astro';
import PhoneInput from '@components/ui/forms/input/PhoneInput.astro';
import TextAreaInput from '@components/ui/forms/input/TextAreaInput.astro';
import Icon from '@components/ui/icons/Icon.astro';
import { COMPANY } from '@data/constants';

// Define the variables that will be used in this component
const title: string = 'Contact us';
const subTitle: string =
  'Tell us about your property goals and we will follow up with the right next step for your project.';
const formTitle: string = 'Request an estimate';
const formSubTitle: string = `Send your project details directly to ${COMPANY.email}.`;
const web3formsAccessKey = import.meta.env.WEB3FORMS_ACCESS_KEY;
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
---

{/* Contact Us */}
<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>

        {/* Success/Error Message Display */}
        <div id="message-container" class="mb-4 hidden rounded-lg p-4">
          <div class="flex">
            <div class="flex-shrink-0">
              <svg
                id="message-icon"
                class="h-5 w-5"
                viewBox="0 0 20 20"
                fill="rgb(47,88,61)"
              >
                <!-- Check circle icon for success -->
                <path
                  id="check-icon"
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"></path>
                <!-- Exclamation triangle icon for error -->
                <path
                  id="error-icon"
                  class="hidden"
                  fill-rule="evenodd"
                  d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                  clip-rule="evenodd"></path>
              </svg>
            </div>
            <div class="ml-3">
              <p class="text-sm font-medium" id="message-text"></p>
            </div>
          </div>
        </div>

        {
          /* Form for user input with various input fields.-->
        {/* Each field utilizes a different input component for the specific type of input (text, email, phone, and textarea)*/
        }
        <form
          id="contact-form"
          action="https://api.web3forms.com/submit"
          method="POST"
        >
          <input type="hidden" name="access_key" value={web3formsAccessKey} />
          <input
            type="hidden"
            name="subject"
            value="Hawthorn Scapes estimate request"
          />
          <input
            type="hidden"
            name="from_name"
            value="Hawthorn Scapes Website"
          />
          <input
            type="checkbox"
            name="botcheck"
            class="hidden"
            tabindex="-1"
            autocomplete="off"
          />
          <input
            type="hidden"
            name="g-recaptcha-response"
            id="g-recaptcha-response"
          />
          <div class="grid gap-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <TextInput
                id="hs-firstname-contacts"
                label="First Name"
                name="firstName"
                autocomplete="given-name"
                required={true}
              />
              <TextInput
                id="hs-lastname-contacts"
                label="Last Name"
                name="lastName"
                autocomplete="family-name"
                required={true}
              />
            </div>
            <EmailContactInput
              id="hs-email-contacts"
              name="email"
              required={true}
            />
            <PhoneInput id="hs-phone-number" name="phone" />
            <TextAreaInput
              id="hs-about-contacts"
              label="Details"
              name="details"
              required={true}
            />
          </div>

          <div class="mt-4 grid">
            <button
              type="submit"
              id="submit-btn"
              class="inline-flex items-center justify-center gap-x-2 rounded-lg border border-transparent bg-yellow-500 px-4 py-3 text-sm font-semibold text-neutral-900 shadow-sm shadow-yellow-200 hover:bg-yellow-600 disabled:pointer-events-none disabled:opacity-50 dark:bg-yellow-400 dark:text-neutral-900 dark:hover:bg-yellow-300 dark:focus:ring-1 dark:focus:ring-yellow-500"
            >
              <span id="btn-text">Send Message</span>
              <div
                id="loading-spinner"
                class="hidden h-4 w-4 animate-spin rounded-full border-2 border-neutral-900 border-t-transparent"
                aria-hidden="true"
              >
              </div>
            </button>
          </div>

          <div class="mt-3 text-center">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
          </div>
        </form>
      </div>

      {
        /*ContactIconBlocks are used to display different methods of contacting, including visiting office, email, browsing knowledgebase, and FAQ.*/
      }
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="Service area"
          content="Serving the Boulder Area through Colorado Springs."
          isLinkVisible={true}
          linkTitle="See service area"
          linkURL="/#service-area"
          isArrowVisible={true}
          ><Icon name="question" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Call us"
          content="Talk through your project scope or timing directly."
          isLinkVisible={true}
          linkTitle={COMPANY.phone}
          linkURL={COMPANY.phoneHref}
          isArrowVisible={true}
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Primary service hub"
          content="Littleton, Colorado"
          isAddressVisible={true}
          addressContent="Boulder Area to Colorado Springs"
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Contact us by email"
          content="Prefer email? Reach us at"
          isLinkVisible={true}
          linkTitle={COMPANY.email}
          linkURL={`mailto:${COMPANY.email}`}
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>
      </div>
    </div>
  </div>
</section>

<script
  src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`}
></script>

<script define:vars={{ recaptchaSiteKey }}>
  // Form submission handler
  document
    .getElementById('contact-form')
    .addEventListener('submit', async function (e) {
      e.preventDefault();

      const submitBtn = document.getElementById('submit-btn');
      const btnText = document.getElementById('btn-text');
      const loadingSpinner = document.getElementById('loading-spinner');
      const messageContainer = document.getElementById('message-container');
      const messageText = document.getElementById('message-text');
      const checkIcon = document.getElementById('check-icon');
      const errorIcon = document.getElementById('error-icon');

      // Show loading state
      submitBtn.disabled = true;
      btnText.textContent = 'Sending...';
      loadingSpinner.classList.remove('hidden');
      loadingSpinner.classList.add('inline-block');
      messageContainer.classList.add('hidden');

      // Get reCAPTCHA token
      try {
        const token = await grecaptcha.execute(recaptchaSiteKey, {
          action: 'submit',
        });
        document.getElementById('g-recaptcha-response').value = token;
      } catch (err) {
        console.error('reCAPTCHA error:', err);
      }

      const formData = new FormData(this);

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (result.success) {
          // Success message
          messageContainer.className =
            'mb-4 p-4 rounded-lg bg-green-50 border border-green-200 dark:bg-green-900 dark:border-green-700';
          messageText.className =
            'text-sm font-medium text-[rgb(47,88,61)] dark:text-green-200';
          checkIcon.classList.remove('hidden');
          errorIcon.classList.add('hidden');
          messageText.textContent =
            "Thank you! Your message has been sent successfully. We'll get back to you soon.";
          messageContainer.classList.remove('hidden');
          this.reset(); // Clear the form
        } else {
          // Error message
          messageContainer.className =
            'mb-4 p-4 rounded-lg bg-red-50 border border-red-200 dark:bg-red-900 dark:border-red-700';
          messageText.className =
            'text-sm font-medium text-red-800 dark:text-red-200';
          checkIcon.classList.add('hidden');
          errorIcon.classList.remove('hidden');
          messageText.textContent =
            'Sorry, there was an error sending your message. Please try again or contact us directly.';
          messageContainer.classList.remove('hidden');
        }
      } catch (error) {
        // Error message
        messageContainer.className =
          'mb-4 p-4 rounded-lg bg-red-50 border border-red-200 dark:bg-red-900 dark:border-red-700';
        messageText.className =
          'text-sm font-medium text-red-800 dark:text-red-200';
        checkIcon.classList.add('hidden');
        errorIcon.classList.remove('hidden');
        messageText.textContent =
          'Sorry, there was an error sending your message. Please try again or contact us directly.';
        messageContainer.classList.remove('hidden');
      }

      // Reset loading state
      submitBtn.disabled = false;
      btnText.textContent = 'Send Message';
      loadingSpinner.classList.add('hidden');
      loadingSpinner.classList.remove('inline-block');
    });
</script>
