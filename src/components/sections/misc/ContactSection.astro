---
// Import the necessary dependencies.
import AuthBtn from '@components/ui/buttons/AuthBtn.astro';
import ContactIconBlock from '@components/ui/blocks/ContactIconBlock.astro';
import TextInput from '@components/ui/forms/input/TextInput.astro';
import EmailContactInput from '@components/ui/forms/input/EmailContactInput.astro';
import PhoneInput from '@components/ui/forms/input/PhoneInput.astro';
import TextAreaInput from '@components/ui/forms/input/TextAreaInput.astro';
import Icon from '@components/ui/icons/Icon.astro';
import { COMPANY } from '@data/constants';

// Define the variables that will be used in this component
const title: string = 'Contact us';
const subTitle: string =
  'Tell us about your property goals and we will follow up with the right next step for your project.';
const formTitle: string = 'Request an estimate';
const formSubTitle: string = `Send your project details directly to ${COMPANY.email}.`;
---

{/* Contact Us */}
<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>
        {
          /* Form for user input with various input fields.-->
        {/* Each field utilizes a different input component for the specific type of input (text, email, phone, and textarea)*/
        }
        <form action={`https://formsubmit.co/${COMPANY.email}`} method="POST">
          <input
            type="hidden"
            name="_subject"
            value="Hawthorn Scapes estimate request"
          />
          <input
            type="hidden"
            name="_next"
            value="https://hawthornscapes.com/?contact=success"
          />
          <input
            type="hidden"
            name="_url"
            value="https://hawthornscapes.com/#contact"
          />
          <input type="hidden" name="_template" value="table" />
          <input
            type="hidden"
            name="_autoresponse"
            value="Thanks for reaching out! We will review your request and reply shortly."
          />
          <input
            type="text"
            name="_honey"
            class="hidden"
            tabindex="-1"
            autocomplete="off"
          />
          <div class="grid gap-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <TextInput
                id="hs-firstname-contacts"
                label="First Name"
                name="firstName"
                autocomplete="given-name"
                required={true}
              />
              <TextInput
                id="hs-lastname-contacts"
                label="Last Name"
                name="lastName"
                autocomplete="family-name"
                required={true}
              />
            </div>
            <EmailContactInput
              id="hs-email-contacts"
              name="email"
              required={true}
            />
            <PhoneInput id="hs-phone-number" name="phone" />
            <TextAreaInput
              id="hs-about-contacts"
              label="Details"
              name="details"
              required={true}
            />
          </div>

          <div class="mt-4 grid">
            <AuthBtn title="Send Message" />
          </div>

          <div class="mt-3 text-center">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
          </div>
        </form>
      </div>

      {
        /*ContactIconBlocks are used to display different methods of contacting, including visiting office, email, browsing knowledgebase, and FAQ.*/
      }
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="Service area"
          content="Serving the Boulder Area through Colorado Springs."
          isLinkVisible={true}
          linkTitle="See service area"
          linkURL="/#service-area"
          isArrowVisible={true}
          ><Icon name="question" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Call us"
          content="Talk through your project scope or timing directly."
          isLinkVisible={true}
          linkTitle={COMPANY.phone}
          linkURL={COMPANY.phoneHref}
          isArrowVisible={true}
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Primary service hub"
          content="Littleton, Colorado"
          isAddressVisible={true}
          addressContent="Boulder Area to Colorado Springs"
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Contact us by email"
          content="Prefer email? Reach us at"
          isLinkVisible={true}
          linkTitle={COMPANY.email}
          linkURL={`mailto:${COMPANY.email}`}
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>
      </div>
    </div>
  </div>
</section>
