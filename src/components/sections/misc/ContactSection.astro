---
// Import the necessary dependencies.
import AuthBtn from '@components/ui/buttons/AuthBtn.astro';
import ContactIconBlock from '@components/ui/blocks/ContactIconBlock.astro';
import TextInput from '@components/ui/forms/input/TextInput.astro';
import EmailContactInput from '@components/ui/forms/input/EmailContactInput.astro';
import PhoneInput from '@components/ui/forms/input/PhoneInput.astro';
import TextAreaInput from '@components/ui/forms/input/TextAreaInput.astro';
import Icon from '@components/ui/icons/Icon.astro';
import { COMPANY } from '@data/constants';

// Define the variables that will be used in this component
const title: string = 'Contact us';
const subTitle: string =
  "Tell us about your property goals and we will follow up with the right next step for your project.";
const formTitle: string = 'Request an estimate';
const formSubTitle: string =
  `Send your project details directly to ${COMPANY.email}.`;
---

{/* Contact Us */}
<section class="mx-auto max-w-[85rem] px-4 py-10 sm:px-6 lg:px-8 lg:py-14">
  <div class="mx-auto max-w-2xl lg:max-w-5xl">
    <div class="text-center">
      <h1
        class="text-2xl font-bold tracking-tight text-balance text-neutral-800 md:text-4xl md:leading-tight dark:text-neutral-200"
      >
        {title}
      </h1>
      <p class="mt-1 text-pretty text-neutral-600 dark:text-neutral-400">
        {subTitle}
      </p>
    </div>

    <div class="mt-12 grid items-center gap-6 lg:grid-cols-2 lg:gap-16">
      <div class="flex flex-col rounded-xl p-4 sm:p-6 lg:p-8">
        <h2
          class="mb-8 text-xl font-bold text-neutral-700 dark:text-neutral-300"
        >
          {formTitle}
        </h2>
        {
          /* Form for user input with various input fields.-->
        {/* Each field utilizes a different input component for the specific type of input (text, email, phone, and textarea)*/
        }
        <form
          data-contact-form
          action={`https://formsubmit.co/${COMPANY.email}`}
          method="POST"
          data-endpoint={`https://formsubmit.co/ajax/${COMPANY.email}`}
          data-subject-prefix="Hawthorn Scapes estimate request"
          data-success-message="Thanks, your request was sent. We will follow up soon."
          data-fallback-message={`We could not send the form right now. Email ${COMPANY.email} or call ${COMPANY.phone}.`}
        >
          <input type="hidden" name="_subject" value="Hawthorn Scapes estimate request" />
          <input type="hidden" name="_next" value="https://hawthornscapes.com/?contact=success" />
          <input type="hidden" name="_captcha" value="true" />
          <input type="hidden" name="_template" value="table" />
          <input type="hidden" name="_autoresponse" value="Thanks for reaching out! We will review your request and reply shortly." />
          <input type="text" name="_honey" class="hidden" tabindex="-1" autocomplete="off" />
          <div class="grid gap-4">
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
              <TextInput
                id="hs-firstname-contacts"
                label="First Name"
                name="firstName"
                autocomplete="given-name"
                required={true}
              />
              <TextInput
                id="hs-lastname-contacts"
                label="Last Name"
                name="lastName"
                autocomplete="family-name"
                required={true}
              />
            </div>
            <EmailContactInput
              id="hs-email-contacts"
              name="email"
              required={true}
            />
            <PhoneInput id="hs-phone-number" name="phone" />
            <TextAreaInput
              id="hs-about-contacts"
              label="Details"
              name="details"
              required={true}
            />
          </div>

          <div class="mt-4 grid">
            <AuthBtn title="Send Message" />
          </div>

          <div class="mt-3 text-center">
            <p class="text-sm text-neutral-600 dark:text-neutral-400">
              {formSubTitle}
            </p>
            <p
              data-form-status
              class="mt-3 hidden rounded-lg border px-4 py-3 text-left text-sm dark:bg-brand-950/30"
            >
            </p>
          </div>
        </form>
      </div>

      {
        /*ContactIconBlocks are used to display different methods of contacting, including visiting office, email, browsing knowledgebase, and FAQ.*/
      }
      <div class="divide-y divide-neutral-300 dark:divide-neutral-700">
        <ContactIconBlock
          heading="Service area"
          content="Serving Metro Denver through Colorado Springs."
          isLinkVisible={true}
          linkTitle="See service area"
          linkURL="/#service-area"
          isArrowVisible={true}
          ><Icon name="question" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Call us"
          content="Talk through your project scope or timing directly."
          isLinkVisible={true}
          linkTitle={COMPANY.phone}
          linkURL={COMPANY.phoneHref}
          isArrowVisible={true}
          ><Icon name="chatBubble" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Primary service hub"
          content="Littleton, Colorado"
          isAddressVisible={true}
          addressContent="Metro Denver to Colorado Springs"
          ><Icon name="mapPin" />
        </ContactIconBlock>

        <ContactIconBlock
          heading="Contact us by email"
          content="Prefer email? Reach us at"
          isLinkVisible={true}
          linkTitle={COMPANY.email}
          linkURL={`mailto:${COMPANY.email}`}
          ><Icon name="envelopeOpen" />
        </ContactIconBlock>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  const initContactForms = () => {
    document.querySelectorAll('[data-contact-form]').forEach(formElement => {
      const form = formElement;
      if (!(form instanceof HTMLFormElement) || form.dataset.initialized === 'true') {
        return;
      }

      form.dataset.initialized = 'true';
      const status = form.querySelector('[data-form-status]');

      form.addEventListener('submit', event => {
        event.preventDefault();

        if (!form.reportValidity()) {
          return;
        }

        const formData = new FormData(form);
        const firstName = `${formData.get('firstName') || ''}`.trim();
        const lastName = `${formData.get('lastName') || ''}`.trim();
        const email = `${formData.get('email') || ''}`.trim();
        const fullName = [firstName, lastName].filter(Boolean).join(' ');
        const subjectPrefix = form.dataset.subjectPrefix || 'Project request';
        const endpoint = form.dataset.endpoint || '';
        const successMessage =
          form.dataset.successMessage ||
          'Your request has been sent successfully.';
        const fallbackMessage =
          form.dataset.fallbackMessage ||
          'We could not send your request right now.';

        formData.set('_subject', `${subjectPrefix} - ${fullName}`);
        formData.set('_replyto', email);
        formData.set('_cc', '');
        formData.set('name', fullName);
        formData.set('page', window.location.href);

        const setStatus = (message, isError = false) => {
          if (!(status instanceof HTMLElement)) return;
          status.textContent = message;
          status.classList.remove('hidden');
          status.className =
            `mt-3 rounded-lg border px-4 py-3 text-left text-sm ${
              isError
                ? 'border-red-200 bg-red-50 text-red-900 dark:border-red-900 dark:bg-red-950/30 dark:text-red-100'
                : 'border-brand-200 bg-brand-50 text-brand-900 dark:border-brand-900 dark:bg-brand-950/30 dark:text-brand-100'
            }`;
        };

        fetch(endpoint, {
          method: 'POST',
          headers: {
            Accept: 'application/json',
          },
          body: formData,
        })
          .then(async response => {
            if (!response.ok) {
              throw new Error('Request failed');
            }
            const data = await response.json();
            if (data.success !== 'true' && data.success !== true) {
              throw new Error('Submission failed');
            }
            form.reset();
            setStatus(successMessage);
          })
          .catch(() => {
            setStatus(fallbackMessage, true);
          });
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initContactForms);
  } else {
    initContactForms();
  }
</script>
