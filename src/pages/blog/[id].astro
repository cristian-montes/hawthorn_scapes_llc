---
import RedirectPage from '@/components/RedirectPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ id }) => id.startsWith('en/'));

  return blogEntries.map(blogEntry => ({
    params: { id: blogEntry.id.replace(/^en\//, '') },
  }));
}
---

<RedirectPage
  title="Article Moved"
  description="This article route has been retired. Visit the Hawthorn Scapes services page for the current company offering."
  target="/services"
  linkLabel="View services"
/>
