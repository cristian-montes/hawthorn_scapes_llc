---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import ContactSection from '@components/sections/misc/ContactSection.astro';
import { SITE } from '@data/constants';

const pageTitle: string = `Contact | ${SITE.title}`;
const metaDescription =
  'Request an estimate or ask a question. Hawthorn Scapes serves from Boulder through Colorado Springs with maintenance, xeriscaping, and hardscape services.';
const ogTitle = `Contact | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://hawthornscapes.com/contact',
    url: 'https://hawthornscapes.com/contact',
    name: `Contact | ${SITE.title}`,
    description:
      'Request an estimate or ask a question. Hawthorn Scapes serves the Boulder through Colorado Springs with maintenance, xeriscaping, and hardscape services.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://hawthornscapes.com',
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: 'en-US',
  }}
>
  <ContactSection />
</MainLayout>
