---
import RedirectPage from '@/components/RedirectPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ id }) => id.startsWith('fr/'));

  return blogEntries.map(blogEntry => ({
    params: { id: blogEntry.id.replace(/^fr\//, '') },
  }));
}
---

<RedirectPage
  lang="fr"
  title="Article déplacé"
  description="Cette page a été retirée. Consultez les services Hawthorn Scapes pour voir l’offre actuelle."
  target="/fr/services"
  linkLabel="Voir les services"
/>
