---
// Import the necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import ContactSection from '@components/sections/fr/ContactSection_fr.astro';
import { SITE } from '@data/constants';

const pageTitle: string = `Nous Contacter | ${SITE.title}`;
const metaDescription =
  "Demandez une estimation ou posez vos questions. Hawthorn Scapes dessert Metro Denver jusqu'à Colorado Springs.";
const ogTitle = `Nous Contacter | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  lang="fr"
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://hawthornscapes.com/fr/contact',
    url: 'https://hawthornscapes.com/fr/contact',
    name: `Nous Contacter | ${SITE.title}`,
    description:
      "Demandez une estimation ou posez vos questions. Hawthorn Scapes dessert Metro Denver jusqu'à Colorado Springs.",
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://hawthornscapes.com/fr/',
      name: SITE.title,
      description:
        SITE.description,
    },
    inLanguage: 'fr',
  }}
>
  <ContactSection />
</MainLayout>
