---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import ContactSectionFr from '@components/sections/fr/ContactSection_fr.astro';
import Icon from '@components/ui/icons/Icon.astro';
import heroImage from '@images/hero-image.avif';
import featureImage from '@images/features-image.avif';

const keyServiceFeatures = [
  {
    heading: 'Entretien',
    content:
      'Tonte, bordures, nettoyages saisonniers et taille pour garder votre aménagement net toute l’année.',
    svg: 'tools',
  },
  {
    heading: 'Installations',
    content:
      'Plantations, xéropaysagisme et aménagements sur mesure pensés pour les conditions du Colorado.',
    svg: 'verified',
  },
  {
    heading: 'Structures',
    content:
      'Clôtures, murets, hardscape et retrait de souches pour des espaces extérieurs plus solides et plus utiles.',
    svg: 'house',
  },
];

const processSteps = [
  {
    title: 'Consulter',
    icon: 'books',
    description:
      'Commencer par une visite de propriété et un plan pratique adapté au climat du Colorado.',
  },
  {
    title: 'Concevoir',
    icon: 'frame',
    description:
      'Créer un aménagement durable qui équilibre beauté, efficacité hydrique et faible entretien.',
  },
  {
    title: 'Réaliser',
    icon: 'tools',
    description:
      'Installer plantation, irrigation et hardscape avec des matériaux de qualité et des méthodes éprouvées.',
  },
  {
    title: 'Entretenir',
    icon: 'verified',
    description:
      'Garder votre propriété saine et impeccable avec un entretien continu et saisonnier.',
  },
];

const serviceAreas = [
  'Littleton',
  'Highlands Ranch',
  'Castle Rock',
  'Centennial',
  'Denver',
  'Colorado Springs',
];

const faqItems = [
  {
    question: 'En combien de temps pouvez-vous planifier une consultation ?',
    answer:
      'Nous répondons généralement dans les 24 heures et pouvons organiser une visite sur place dans la semaine selon nos disponibilités.',
  },
  {
    question: 'Proposez-vous des aménagements à faible consommation d’eau ?',
    answer:
      'Oui. Nous réalisons du xéropaysagisme, des plantations adaptées au climat local et des solutions minérales qui réduisent la consommation d’eau.',
  },
  {
    question: 'Pouvez-vous entretenir un aménagement existant de façon récurrente ?',
    answer:
      'Absolument. Nous proposons des plans hebdomadaires, bihebdomadaires et saisonniers pour garder votre propriété saine et ordonnée.',
  },
];
---

<MainLayout
  lang="fr"
  title="Hawthorn Scapes | Aménagement paysager au Colorado"
  customDescription="Services professionnels d’aménagement paysager, xéropaysagisme, hardscape et entretien de Metro Denver à Colorado Springs."
>
  <HeroSection
    title="Hawthorn Scapes pour le Front Range."
    subTitle="Services professionnels d’aménagement paysager et de xéropaysagisme adaptés au climat du Colorado. De Littleton à Colorado Springs."
    primaryBtn="Demander un devis"
    primaryBtnURL="#contact"
    secondaryBtn="Voir les services"
    secondaryBtnURL="#services"
    withReview={false}
    src={heroImage}
    alt="Aménagement paysager du Colorado avec pierre, graminées et arrière-plan montagneux"
  />

  <div id="services">
    <FeaturesGeneral
      title="Services pour les paysages du Colorado"
      subTitle="Trois grands pôles de service : entretien, installations et structures extérieures conçues pour le climat du Front Range."
      src={featureImage}
      alt="Détail de pierre naturelle et de plantations sobres en eau"
      features={keyServiceFeatures}
    />
  </div>

  <section class="mx-auto max-w-[85rem] px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.32em] text-brand-600">
        Notre approche
      </p>
      <h2 class="mt-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        Un processus simple en 4 étapes pour les propriétés du Colorado
      </h2>
      <p class="mt-4 text-base text-neutral-600 dark:text-neutral-400">
        De la première visite jusqu’à l’entretien continu, nous gardons chaque projet clair, fiable et ancré dans la performance réelle du paysage.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {processSteps.map(step => (
        <div class="rounded-3xl border border-brand-100/80 bg-white p-6 text-center shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
          <div class="mx-auto mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-brand-50 text-brand-700 dark:bg-brand-900 dark:text-brand-300">
            <Icon name={step.icon} />
          </div>
          <h3 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">
            {step.title}
          </h3>
          <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </section>

  <section id="service-area" class="mx-auto max-w-[85rem] px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.32em] text-brand-600">
        Zone desservie
      </p>
      <h2 class="mt-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        Nous desservons le Front Range de Littleton à Colorado Springs
      </h2>
      <p class="mt-4 text-base text-neutral-600 dark:text-neutral-400">
        Nous concevons des systèmes paysagers régionaux capables de performer dans le climat saisonnier du Colorado avec une approche durable et raisonnée de l’eau.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {serviceAreas.map(city => (
        <div class="rounded-3xl border border-brand-100/80 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
          <p class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">{city}</p>
        </div>
      ))}
    </div>
  </section>

  <section id="faq" class="mx-auto max-w-[85rem] px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm font-semibold uppercase tracking-[0.32em] text-brand-600">
        Réponses utiles
      </p>
      <h2 class="mt-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100">
        Questions fréquentes
      </h2>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {faqItems.map(item => (
        <article class="rounded-3xl border border-brand-100/80 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
          <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">
            {item.question}
          </h3>
          <p class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
            {item.answer}
          </p>
        </article>
      ))}
    </div>
  </section>

  <div id="contact">
    <ContactSectionFr />
  </div>
</MainLayout>
