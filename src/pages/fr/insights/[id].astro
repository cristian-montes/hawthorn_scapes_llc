---
import RedirectPage from '@/components/RedirectPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const insightEntries = await getCollection('insights', ({ id }) =>
    id.startsWith('fr/')
  );

  return insightEntries.map(insightEntry => ({
    params: { id: insightEntry.id.replace(/^fr\//, '') },
  }));
}
---

<RedirectPage
  lang="fr"
  title="Analyse déplacée"
  description="Cette page a été retirée. Consultez les services Hawthorn Scapes pour voir l’offre actuelle."
  target="/fr/services"
  linkLabel="Voir les services"
/>
