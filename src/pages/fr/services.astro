---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';
import { SITE } from '@data/constants';

// Import necessary images
import heroImage from '@images/hero-image.avif';
import featureImage from '@images/features-image.avif';
import beforeAfter from '@images/before-after.avif';
import aerialView from '@images/aerial-view.avif';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Entretien de pelouse',
    subTitle:
      'Tonte, bordures, taille et nettoyages saisonniers pour garder votre propriété nette toute l’année.',
    single: false,
    imgOne: heroImage,
    imgOneAlt: 'Pelouse du Colorado bien entretenue avec bordures nettes et massifs soignes.',
    imgTwo: aerialView,
    imgTwoAlt: "Vue aerienne d'une propriete amenagee avec des espaces exterieurs entretenus.",
  },
  {
    isRightSection: false,
    title: 'Installation arbres et arbustes',
    subTitle:
      "Nous installons des espèces adaptées au climat du Colorado, avec une planification selon l'altitude et le sol local.",
    img: featureImage,
    imgAlt: 'Massif plante avec graminees locales, bordures en pierre et textures paysageres.',
    btnExists: true,
    btnTitle: 'Demander une estimation',
    btnURL: '/fr/contact',
  },
  {
    isRightSection: true,
    title: 'Xéropaysagisme',
    subTitle:
      "Conceptions paysagères à faible consommation d'eau, modernes et simples à entretenir.",
    single: false,
    imgOne: featureImage,
    imgOneAlt: 'Details de xeroamenagement avec pierre decorative et plantations peu gourmandes en eau.',
    imgTwo: heroImage,
    imgTwoAlt: 'Amenagement xerique du Colorado avec pierre, graminees et relief naturel.',
  },
  {
    isRightSection: false,
    title: 'Murets et aménagements minéraux',
    subTitle:
      'Murets de soutènement et hardscape conçus pour la durabilité, le drainage et la gestion de pente.',
    img: beforeAfter,
    imgAlt:
      'Transformation paysagere montrant un amenagement en pierre, des plantations et une structure exterieure terminee.',
  },
  {
    isRightSection: true,
    title: 'Clôtures et structures extérieures',
    subTitle:
      'Clôtures résidentielles et éléments structurels réalisés avec une finition propre et professionnelle.',
    single: false,
    imgOne: aerialView,
    imgOneAlt: "Vue d'ensemble d'une propriete avec zones exterieures bien definies et amenagement structure.",
    imgTwo: heroImage,
    imgTwoAlt: 'Paysage termine du Front Range avec pierre decorative et plantations etagees.',
    btnExists: true,
    btnTitle: 'Commencer votre projet',
    btnURL: '/fr/contact',
  },
];
---

<MainLayout
  title={`Services | ${SITE.title}`}
  lang="fr"
  customDescription="Services de paysage Hawthorn Scapes : entretien, xéropaysagisme, plantations, murets et clôtures."
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://hawthornscapes.com/fr/services',
    url: 'https://hawthornscapes.com/fr/services',
    name: `Services | ${SITE.title}`,
    description:
      "Services de paysage Hawthorn Scapes : entretien, xéropaysagisme, plantations, murets et clôtures.",
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://hawthornscapes.com/fr',
      name: SITE.title,
      description:
        SITE.description,
    },
    inLanguage: 'fr',
  }}
>
  {
    /* MainSection is the introductory section of the page, it also contains a CTA button */
  }
  <MainSection
    title="Services paysagers conçus pour le Colorado"
    subTitle="Hawthorn Scapes propose des solutions durables et adaptées au climat du Front Range."
    btnExists={true}
    btnTitle="Demander une estimation"
    btnURL="/fr/contact"
  />
  {
    /* RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  */
  }
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  {/* FeaturesStats section showcases essential stats valuable to users */}
  <FeaturesStats
    title="Par les chiffres"
    subTitle="Notre approche privilégie la qualité d'exécution, la communication et la fiabilité."
    mainStatTitle="100%"
    mainStatSubTitle="des projets avec une portée adaptée à votre propriété"
    stats={[
      {
        stat: '6',
        description: 'zones principales desservies',
      },
      {
        stat: '4',
        description: 'saisons intégrées au cycle de maintenance',
      },
      {
        stat: '1',
        description: 'équipe dédiée du devis à la livraison',
      },
    ]}
  />
</MainLayout>
