---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import FeaturesNavs from '@components/sections/features/FeaturesNavs.astro';
import FAQ from '@components/sections/misc/FAQ.astro';
import heroImage from '@images/hero-image.avif';
import featureImage from '@images/features-image.avif';
import construction from '@images/construction-image.avif';
import tools from '@images/automated-tools.avif';
import dashboard from '@images/dashboard-image.avif';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LandscapingService',
  name: 'Hawthorn Scapes, LLC',
  image:
    'https://hawthornscapes.com/Gemini_Generated_Image_3zlccl3zlccl3zlc.png',
  url: 'https://hawthornscapes.com',
  telephone: 'YOUR_PHONE_NUMBER',
  priceRange: '$$',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'YOUR_BUSINESS_ADDRESS',
    addressLocality: 'Littleton',
    addressRegion: 'CO',
    postalCode: '80120',
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 39.5807,
    longitude: -104.9772,
  },
  areaServed: [
    { '@type': 'City', name: 'Denver' },
    { '@type': 'City', name: 'Littleton' },
    { '@type': 'City', name: 'Centennial' },
    { '@type': 'City', name: 'Highlands Ranch' },
    { '@type': 'City', name: 'Castle Rock' },
    { '@type': 'City', name: 'Colorado Springs' },
  ],
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Landscaping Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Xeriscaping' } },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Hardscape & Retaining Walls' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Tree & Shrub Installation' },
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Lawn Mowing & Maintenance' },
      },
    ],
  },
};

const keyServiceFeatures = [
  {
    heading: 'Colorado-Hardy Planting',
    content:
      'Tree and shrub installation planned for altitude, sun exposure, and soil conditions along the Front Range.',
    svg: 'hammer',
  },
  {
    heading: 'Water-Efficient Xeriscaping',
    content:
      'Low-maintenance, modern yards that preserve curb appeal while reducing water usage during dry Colorado summers.',
    svg: 'earth',
  },
  {
    heading: 'Engineered Hardscapes',
    content:
      'Retaining walls and stonework designed for drainage, slope control, and long-term durability.',
    svg: 'verified',
  },
  {
    heading: 'Reliable Ongoing Care',
    content:
      'Scheduled mowing, edging, and seasonal cleanups that keep your landscape neat year-round.',
    svg: 'community',
  },
];

const faqs = [
  {
    question: 'What areas do you serve?',
    answer:
      'We serve Metro Denver through Colorado Springs, including Littleton, Centennial, Highlands Ranch, and Castle Rock.',
  },
  {
    question: 'Do you offer xeriscaping?',
    answer:
      'Yes. We design and install water-efficient xeriscape solutions that fit your property style and maintenance goals.',
  },
  {
    question: 'Can you handle both design and install?',
    answer:
      'Yes. We provide end-to-end projects from planning and material selection to construction and finishing.',
  },
  {
    question: 'How do I request an estimate?',
    answer:
      'Use our contact form to share your project details and we will follow up with next steps and scheduling options.',
  },
];
---

<MainLayout
  title="Hawthorn Scapes | Colorado Landscaping"
  customDescription="Professional landscaping, xeriscaping, hardscaping, and maintenance services across Metro Denver to Colorado Springs."
  structuredData={localBusinessSchema}
>
  <HeroSection
    title=`Colorado Landscaping Done <span class="text-brand-600 dark:text-brand-400">Right</span>`
    subTitle="Hawthorn Scapes provides professional maintenance, custom landscape installation, and hardscape solutions built for the Front Range climate."
    primaryBtn="Request a Free Estimate"
    primaryBtnURL="/contact"
    secondaryBtn="View Services"
    secondaryBtnURL="/contact"
    withReview={false}
    src={heroImage}
    alt="Landscape installation and maintenance project"
  />

  <FeaturesGeneral
    title="Built for Front Range Conditions"
    subTitle="From drought-friendly design to long-lasting hardscape builds, we focus on practical landscapes that look clean and perform season after season."
    src={featureImage}
    alt="Hardscape and landscape project details"
    features={keyServiceFeatures}
  />

  <FeaturesNavs
    title=`Services Built for <span class="text-brand-600 dark:text-brand-400">Colorado Homes</span>`
    tabs={[
      {
        heading: 'Lawn & Maintenance',
        content:
          'Scheduled mowing, edging, seasonal clean-ups, and trimming to keep your property sharp through every season.',
        svg: 'tools',
        src: tools,
        alt: 'Lawn maintenance service in Colorado',
        first: true,
      },
      {
        heading: 'Installation & Design',
        content:
          'Tree and shrub installation, custom landscape design, and xeriscaping tailored to local climate and soil conditions.',
        svg: 'dashboard',
        src: dashboard,
        alt: 'Custom landscape installation and xeriscape design',
        second: true,
      },
      {
        heading: 'Hardscape & Structures',
        content:
          'Retaining walls, stone features, and fencing built for drainage performance, durability, and curb appeal.',
        svg: 'house',
        src: construction,
        alt: 'Retaining wall and hardscape construction',
      },
    ]}
  />

  <section id="service-area" class="mx-auto max-w-[85rem] px-4 sm:px-6 lg:px-8">
    <div class="rounded-xl bg-brand-50 px-6 py-8 dark:bg-white/[.04]">
      <h2 class="text-2xl font-bold text-neutral-800 dark:text-neutral-200">
        Service Area
      </h2>
      <p class="mt-3 text-neutral-600 dark:text-neutral-400">
        Proudly serving Metro Denver through Colorado Springs, including
        Littleton, Centennial, Highlands Ranch, and Castle Rock.
      </p>
    </div>
  </section>

  <section id="faq">
    <FAQ title="Frequently<br />asked questions" faqs={faqs} />
  </section>
</MainLayout>
