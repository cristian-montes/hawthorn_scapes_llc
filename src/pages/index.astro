---
import MainLayout from '@/layouts/MainLayout.astro';
import HeroSection from '@components/sections/landing/HeroSection.astro';
import FeaturesGeneral from '@components/sections/features/FeaturesGeneral.astro';
import ContactSection from '@components/sections/misc/ContactSection.astro';
import Icon from '@components/ui/icons/Icon.astro';
import Hero1Image from '@images/hero_1.png';

const keyServiceFeatures = [
  {
    heading: 'Maintenance',
    content:
      'Mowing, edging, seasonal clean-ups, and trimming that keep your landscape crisp year-round.',
    svg: 'tools',
  },
  {
    heading: 'Installations',
    content:
      'Tree & shrub planting, xeriscaping, and custom landscape installation tailored for Colorado conditions.',
    svg: 'verified',
  },
  {
    heading: 'Structures',
    content:
      'Fences, retaining walls, hardscapes, and stump removal for stronger, more usable outdoor spaces.',
    svg: 'house',
  },
];

const processSteps = [
  {
    title: 'Consult',
    icon: 'books',
    description:
      'Start with a property walkthrough and practical Colorado-focused plan.',
  },
  {
    title: 'Design',
    icon: 'frame',
    description:
      'Build a durable landscape design that balances beauty, water efficiency, and low upkeep.',
  },
  {
    title: 'Build',
    icon: 'tools',
    description:
      'Install hardscape, planting, and irrigation with quality materials and proven techniques.',
  },
  {
    title: 'Maintain',
    icon: 'verified',
    description:
      'Keep your property healthy and clean with ongoing care and seasonal service.',
  },
];

const serviceAreas = [
  'Boulder Area',
  'Littleton',
  'Highlands Ranch',
  'Castle Rock',
  'Centennial',
  'Denver',
  'Colorado Springs',
];

const faqItems = [
  {
    question: 'How soon can I schedule a consultation?',
    answer:
      'We typically respond within 24 hours and can schedule a property walkthrough within one week, depending on availability.',
  },
  {
    question: 'Do you offer drought-friendly landscape designs?',
    answer:
      'Yes — we specialize in xeriscaping, native planting, and hardscape solutions that reduce water use while enhancing outdoor appeal.',
  },
  {
    question: 'Can you maintain existing landscapes on a recurring schedule?',
    answer:
      'Absolutely. We provide weekly, biweekly, and seasonal maintenance plans to keep your landscape healthy and tidy year-round.',
  },
];
---

<MainLayout
  title="Hawthorn Scapes | Colorado Landscaping"
  customDescription="Professional landscaping, xeriscaping, hardscaping, and maintenance services from the Boulder Area to Colorado Springs."
>
  {/* Full logo centered between navbar and hero */}
  <div class="flex justify-center py-8 sm:py-12 md:py-16">
    <img
      src="/full-logo.svg"
      alt="Hawthorn Scapes Full Logo"
      class="h-24 w-auto sm:h-32 md:h-44 lg:h-52 xl:h-60"
      loading="eager"
    />
  </div>

  <HeroSection
    title="Hawthorn Scapes"
    subTitle="Expert landscaping that handles it all — mowing, planting, irrigation, hardscapes, and more — built for Colorado’s climate. Serving the Boulder Area to Colorado Springs.
"
    primaryBtn="Get a Quote"
    primaryBtnURL="#contact"
    secondaryBtn="View Services"
    secondaryBtnURL="/services"
    withReview={false}
    src={Hero1Image}
    alt="Colorado xeriscape garden with rocks and native plants"
  />

  <div id="services">
    <FeaturesGeneral
      title="Services for Colorado Landscapes"
      subTitle="Three core service groups: maintenance, installations, and outdoor structures designed for Colorado’s climate."
      features={keyServiceFeatures}
    />
  </div>

  <section class="mx-auto max-w-[85rem] px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p
        class="text-brand-600 text-sm font-semibold tracking-[0.32em] uppercase"
      >
        How we work
      </p>
      <h2
        class="mt-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100"
      >
        A simple 4-step process built for Colorado properties
      </h2>
      <p class="mt-4 text-base text-neutral-600 dark:text-neutral-400">
        From the first consultation to ongoing maintenance, we keep every
        project clear, reliable, and rooted in practical landscape performance.
      </p>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        processSteps.map(step => (
          <div class="border-brand-100/80 rounded-3xl border bg-white p-6 text-center shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
            <div class="bg-brand-50 text-brand-700 dark:bg-brand-900 dark:text-brand-300 mx-auto mb-5 inline-flex h-14 w-14 items-center justify-center rounded-2xl">
              <Icon name={step.icon} />
            </div>
            <h3 class="text-xl font-semibold text-neutral-900 dark:text-neutral-100">
              {step.title}
            </h3>
            <p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400">
              {step.description}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section
    id="service-area"
    class="mx-auto max-w-[85rem] px-4 pb-16 sm:px-6 lg:px-8"
  >
    <div class="mx-auto max-w-3xl text-center">
      <p
        class="text-brand-600 text-sm font-semibold tracking-[0.32em] uppercase"
      >
        Service Area
      </p>
      <h2
        class="mt-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100"
      >
        Serving Colorado from the Boulder Area to Colorado Springs
      </h2>
      <p class="mt-4 text-base text-neutral-600 dark:text-neutral-400">
        We focus on regional landscape systems that perform in Colorado's
        seasonal climate with water-wise planning and resilient installations.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        serviceAreas.map(city => (
          <div class="border-brand-100/80 rounded-3xl border bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
            <p class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">
              {city}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section id="faq" class="mx-auto max-w-[85rem] px-4 pb-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <p
        class="text-brand-600 text-sm font-semibold tracking-[0.32em] uppercase"
      >
        Questions answered
      </p>
      <h2
        class="mt-4 text-3xl font-bold text-neutral-900 dark:text-neutral-100"
      >
        Frequently asked questions
      </h2>
    </div>

    <div class="mt-10 grid gap-6 sm:grid-cols-2">
      {
        faqItems.map(item => (
          <article class="border-brand-100/80 rounded-3xl border bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
            <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-100">
              {item.question}
            </h3>
            <p class="mt-3 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
              {item.answer}
            </p>
          </article>
        ))
      }
    </div>
  </section>

  <div id="contact">
    <ContactSection />
  </div>
</MainLayout>
