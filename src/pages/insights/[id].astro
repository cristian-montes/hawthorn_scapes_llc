---
import RedirectPage from '@/components/RedirectPage.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const insightEntries = await getCollection('insights', ({ id }) =>
    id.startsWith('en/')
  );

  return insightEntries.map(insightEntry => ({
    params: { id: insightEntry.id.replace(/^en\//, '') },
  }));
}
---

<RedirectPage
  title="Insight Moved"
  description="This insight page has been retired. Visit Hawthorn Scapes services for the live business offering."
  target="/services"
  linkLabel="View services"
/>
