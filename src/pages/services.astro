---
// Import necessary components
import MainLayout from '@/layouts/MainLayout.astro';
import MainSection from '@components/ui/blocks/MainSection.astro';
import LeftSection from '@components/ui/blocks/LeftSection.astro';
import RightSection from '@components/ui/blocks/RightSection.astro';
import FeaturesStats from '@components/sections/features/FeaturesStats.astro';

// Import necessary images
// import heroImage from '@images/hero-image.avif';
// import featureImage from '@images/features-image.avif';
import universalXeriscapeImage from '@images/universal_xeriscape.png';
import modernBareXeriscapeImage from '@images/modern_bare_xeriscape.png';
import cleanYardImage from '@images/clean_front_yard.png';
import hardScapeImage from '@images/hard_scape.png';
import freshLawnImage from '@images/fresh_lawn.jpg';
import fencePergolaImage from '@images/fence_pergola.png';
import railFenceImage from '@images/rail_fence.png';
import treeInstallationImage from '@images/tree_installation.png';
import { SITE } from '@data/constants';

interface Article {
  isRightSection: boolean;
  title: string;
  subTitle: string;
  btnExists?: boolean;
  btnTitle?: string;
  btnURL?: string;
  single?: boolean;
  img?: any;
  imgAlt?: string;
  imgOne?: any;
  imgOneAlt?: string;
  imgTwo?: any;
  imgTwoAlt?: string;
}

const articles: Article[] = [
  {
    isRightSection: true,
    title: 'Lawn & Maintenance',
    subTitle:
      'Reliable mowing, edging, trimming, and seasonal cleanups that keep your property sharp through every Colorado season.',
    single: false,
    imgOne: cleanYardImage,
    imgOneAlt: 'Well-maintained lawn with stone edging and lush plantings.',
    imgTwo: freshLawnImage,
    imgTwoAlt:
      'Aerial view of a landscaped residential property with maintained outdoor areas.',
  },
  {
    isRightSection: false,
    title: 'Tree, Shrub, Flower and Planting Bed Installation',
    subTitle:
      'We install Colorado-hardy trees, shrubs, and planting beds designed for local altitude, soil, and water constraints.',
    img: treeInstallationImage,
    imgAlt:
      'Fresh planting bed with native grasses, stone edging, and layered landscape texture.',
    btnExists: true,
    btnTitle: 'Request an Estimate',
    btnURL: '/contact',
  },
  {
    isRightSection: true,
    title: 'Xeriscaping & Water Efficiency',
    subTitle:
      'Low-maintenance xeriscape designs built to reduce water usage while maintaining clean, modern curb appeal.',
    single: false,
    imgOne: universalXeriscapeImage,
    imgOneAlt:
      'Water-wise planting detail with stone mulch and drought-tolerant grasses.',
    imgTwo: modernBareXeriscapeImage,
    imgTwoAlt:
      'Colorado xeriscape front yard with layered stone, grasses, and mountain backdrop.',
  },
  {
    isRightSection: false,
    title: 'Hardscape & Retaining Walls',
    subTitle:
      'Retaining walls and hardscape features engineered for slope management, drainage performance, and long-term durability.',
    img: hardScapeImage,
    imgAlt:
      'Landscape transformation showing installed stonework, planting beds, and finished outdoor structure details.',
  },
  {
    isRightSection: true,
    title: 'Fencing & Outdoor Structure Work',
    subTitle:
      'Residential fencing and structural landscape elements installed with an emphasis on quality, safety, and lasting value.',
    single: false,
    imgOne: fencePergolaImage,
    imgOneAlt:
      'Residential property layout showing defined outdoor zones and structured landscape lines.',
    imgTwo: railFenceImage,
    imgTwoAlt:
      'Finished Front Range landscape with stone accents and layered planting.',
    btnExists: true,
    btnTitle: 'Start Your Project',
    btnURL: '/contact',
  },
];

const pageTitle: string = `Services | ${SITE.title}`;
const metaDescription =
  'Explore Hawthorn Scapes services including maintenance, xeriscaping, planting, hardscape construction, and fencing from the Boulder Area to Colorado Springs.';
const ogTitle = `Landscaping Services | ${SITE.title}`;
---

<MainLayout
  title={pageTitle}
  customDescription={metaDescription}
  customOgTitle={ogTitle}
  structuredData={{
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    '@id': 'https://hawthornscapes.com/services',
    url: 'https://hawthornscapes.com/services',
    name: `Landscaping Services | ${SITE.title}`,
    description:
      'Explore Hawthorn Scapes services including maintenance, xeriscaping, planting, hardscape construction, and fencing from the Boulder Area to Colorado Springs.',
    isPartOf: {
      '@type': 'WebSite',
      url: 'https://hawthornscapes.com',
      name: SITE.title,
      description: SITE.description,
    },
    inLanguage: 'en-US',
  }}
>
  {
    /* MainSection is the introductory section of the page, it also contains a CTA button */
  }
  <MainSection
    title="Landscaping Services Built for Colorado"
    subTitle="Hawthorn Scapes provides practical, high-quality outdoor solutions designed for Front Range weather, terrain, and water demands."
    btnExists={true}
    btnTitle="Request a Free Estimate"
    btnURL="/contact"
  />
  {
    /* RightSection and LeftSection contain details about various services along with pertinent imagery.
  They alternate for variety in design.
  The 'btnExists' property is used to toggle the display of a button in these sections.
  When btnExists={true}, a button is displayed.
  This can be used to link to more detailed information or related resources.
  RightSection can also conditionally render one or two images based on the 'single' property.
  If 'single' is true, it displays one image, otherwise it displays two.
  */
  }
  {
    articles.map(article => {
      return article.isRightSection ? (
        <RightSection
          title={article.title}
          subTitle={article.subTitle}
          single={article.single}
          imgOne={article.imgOne}
          imgOneAlt={article.imgOneAlt}
          imgTwo={article.imgTwo}
          imgTwoAlt={article.imgTwoAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      ) : (
        <LeftSection
          title={article.title}
          subTitle={article.subTitle}
          img={article.img}
          imgAlt={article.imgAlt}
          btnExists={article.btnExists}
          btnTitle={article.btnTitle}
          btnURL={article.btnURL}
        />
      );
    })
  }
  {/* FeaturesStats section showcases essential stats valuable to users */}
  <FeaturesStats
    title="By the Numbers"
    subTitle="We focus on consistency, communication, and craftsmanship from first walkthrough to final cleanup."
    mainStatTitle="100%"
    mainStatSubTitle="customized scopes built around your property and goals"
    stats={[
      {
        stat: '7',
        description: 'core service areas across the Front Range',
      },
      {
        stat: '4',
        description: 'seasons of planning built into each maintenance cycle',
      },
      {
        stat: '1',
        description: 'single trusted team from estimate to completion',
      },
    ]}
  />
</MainLayout>
