{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; form-action 'self' https://formsubmit.co; frame-src 'self'; frame-ancestors 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://formsubmit.co; object-src 'none'; upgrade-insecure-requests; block-all-mixed-content"
        },
        {
          "key": "Permissions-Policy",
          "value": "interest-cohort=()"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer-when-downgrade"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/blog", "destination": "/services", "permanent": true },
    { "source": "/blog/:id", "destination": "/services", "permanent": true },
    { "source": "/products", "destination": "/services", "permanent": true },
    { "source": "/products/:id", "destination": "/services", "permanent": true },
    { "source": "/insights/:id", "destination": "/services", "permanent": true },
    { "source": "/fr/blog", "destination": "/fr/services", "permanent": true },
    { "source": "/fr/blog/:id", "destination": "/fr/services", "permanent": true },
    { "source": "/fr/products", "destination": "/fr/services", "permanent": true },
    { "source": "/fr/products/:id", "destination": "/fr/services", "permanent": true },
    { "source": "/fr/insights/:id", "destination": "/fr/services", "permanent": true }
  ]
}
